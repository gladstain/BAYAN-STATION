addmood-command-description = Adds a mood effect to an entity with MoodComponent.
addmood-command-help = Usage: { $command } <entityUid> <moodEffectId>
addmood-command-hint-entity = Entity uid with MoodComponent
addmood-command-hint-mood = moodEffect prototype id
addmood-command-error-invalid-uid = Invalid entity uid.
addmood-command-error-missing-component = Target entity does not have MoodComponent.
addmood-command-error-unknown-mood = Unknown mood effect prototype: { $moodId }.
addmood-command-success = Added mood effect { $moodId } to entity { $uid }.

removemood-command-description = Removes a mood effect from an entity with MoodComponent.
removemood-command-help = Usage: { $command } <entityUid> <moodEffectId>
removemood-command-hint-entity = Entity uid with MoodComponent
removemood-command-hint-mood = moodEffect prototype id
removemood-command-error-invalid-uid = Invalid entity uid.
removemood-command-error-missing-component = Target entity does not have MoodComponent.
removemood-command-error-unknown-mood = Unknown mood effect prototype: { $moodId }.
removemood-command-success = Removed mood effect { $moodId } from entity { $uid }.
